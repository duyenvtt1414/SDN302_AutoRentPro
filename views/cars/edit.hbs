<!-- Header -->
<div class="mb-4 pb-3 border-bottom">
  <h1 class="h2 fw-bold" style="color: #2c3e50;">
    <i class="bi bi-pencil-square me-2" style="color: #f39c12;"></i>Edit Car
  </h1>
  <p class="text-muted small mb-0">Update vehicle information</p>
</div>

<!-- Form Card -->
<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
      <div class="card-body p-4">
        <form method="post" action="/ui/cars/{{car._id}}">
          <div class="mb-4">
            <label class="form-label fw-500" style="color: #2c3e50;">Car Name</label>
            <div class="input-group">
              <span class="input-group-text bg-light border-0">
                <i class="bi bi-car-front" style="color: #f39c12;"></i>
              </span>
              <input class="form-control border-0 bg-light" name="name" placeholder="e.g., Toyota Camry" value="{{car.name}}" style="border-radius: 0 8px 8px 0;" required />
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-500" style="color: #2c3e50;">Brand</label>
            <div class="input-group">
              <span class="input-group-text bg-light border-0">
                <i class="bi bi-tag" style="color: #f39c12;"></i>
              </span>
              <input class="form-control border-0 bg-light" name="brand" placeholder="e.g., Toyota" value="{{car.brand}}" style="border-radius: 0 8px 8px 0;" required />
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-500" style="color: #2c3e50;">Price per Day ($)</label>
            <div class="input-group">
              <span class="input-group-text bg-light border-0">
                <i class="bi bi-currency-dollar" style="color: #f39c12;"></i>
              </span>
              <input class="form-control border-0 bg-light" name="pricePerDay" type="number" min="0" placeholder="e.g., 52" value="{{car.pricePerDay}}" style="border-radius: 0 8px 8px 0;" required />
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-500" style="color: #2c3e50;">Status</label>
            <select class="form-select" name="status" style="border-radius: 8px; border: 1px solid #ddd;">
              {{#each statuses}}
                <option value="{{this}}" {{#ifEquals ../car.status this}}selected{{/ifEquals}}>{{this}}</option>
              {{/each}}
            </select>
          </div>

          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a class="btn" href="/ui/cars" style="background: #ecf0f1; color: #2c3e50; border: none; border-radius: 8px; padding: 0.6rem 1.5rem;">
              <i class="bi bi-arrow-left me-2"></i>Back
            </a>
            <button class="btn" type="submit" style="background: #f39c12; color: white; border: none; border-radius: 8px; padding: 0.6rem 1.5rem;">
              <i class="bi bi-check-circle me-2"></i>Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
