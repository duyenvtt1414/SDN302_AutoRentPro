<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="col-md-5">
    <div class="bg-white p-5 rounded-lg shadow-lg border-0" style="border-radius: 15px;">
      <!-- Header -->
      <div class="text-center mb-4">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">
          <i class="bi bi-car-front-fill" style="color: #2c3e50;"></i>
        </div>
        <h1 class="h3 fw-bold" style="color: #2c3e50;">AutoRent Pro</h1>
        <p class="text-muted mb-0">Admin Control Panel</p>
      </div>

      {{#if error}}
        <div class="alert alert-danger d-flex align-items-center" role="alert">
          <i class="bi bi-exclamation-circle-fill me-2"></i>
          <span>{{error}}</span>
        </div>
      {{/if}}

      <!-- Login Form -->
      <form method="post" action="/ui/login">
        <div class="mb-3">
          <label class="form-label fw-500" style="color: #2c3e50;">Email Address</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-envelope" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="email" 
              type="email" 
              placeholder="Enter your email"
              required 
            />
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-500" style="color: #2c3e50;">Password</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-lock-fill" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="password" 
              type="password" 
              placeholder="Enter your password"
              required 
            />
          </div>
        </div>

        <button class="btn btn-primary w-100 fw-600 py-2" style="background: linear-gradient(90deg, #3498db 0%, #2980b9 100%); border: none; border-radius: 8px;">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>

      <!-- Divider -->
      <div class="d-flex align-items-center my-4">
        <div style="flex: 1; border-bottom: 1px solid #ddd;"></div>
        <span class="px-3 text-muted small">or</span>
        <div style="flex: 1; border-bottom: 1px solid #ddd;"></div>
      </div>

      <!-- Sign Up Link -->
      <div class="text-center mb-4">
        <p class="text-muted mb-0">Don't have an account?</p>
        <a href="/ui/signup" class="btn w-100 fw-600 py-2" style="background: #27ae60; color: white; border: none; border-radius: 8px; margin-top: 0.5rem;">
          <i class="bi bi-person-plus me-2"></i>Create Account
        </a>
      </div>

      <!-- Footer -->
      <div class="text-center mt-4">
        <p class="small text-muted">© 2026 AutoRent Pro. All rights reserved.</p>
      </div>
    </div>
  </div>
</div>

<style>
  body {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  }
  .input-group-text {
    border-radius: 8px 0 0 8px !important;
  }
  .form-control {
    border-radius: 0 8px 8px 0 !important;
  }
  .form-control:focus {
    border-color: #3498db !important;
    box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25) !important;
  }
</style>
