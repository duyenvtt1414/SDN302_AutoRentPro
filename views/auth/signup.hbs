<div class="row justify-content-center align-items-center" style="min-height: 100vh;">
  <div class="col-md-6">
    <div class="bg-white p-5 rounded-lg shadow-lg border-0" style="border-radius: 15px;">
      <!-- Header -->
      <div class="text-center mb-4">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">
          <i class="bi bi-car-front-fill" style="color: #2c3e50;"></i>
        </div>
        <h1 class="h3 fw-bold" style="color: #2c3e50;">Create Account</h1>
        <p class="text-muted mb-0">Join AutoRent Pro today</p>
      </div>

      {{#if error}}
        <div class="alert alert-danger d-flex align-items-center" role="alert">
          <i class="bi bi-exclamation-circle-fill me-2"></i>
          <span>{{error}}</span>
        </div>
      {{/if}}

      <!-- Sign Up Form -->
      <form method="post" action="/ui/signup">
        <!-- Full Name -->
        <div class="mb-3">
          <label class="form-label fw-500" style="color: #2c3e50;">Full Name</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-person" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="fullName" 
              type="text" 
              placeholder="Enter your full name"
              value="{{form.fullName}}"
              required 
            />
          </div>
        </div>

        <!-- Email -->
        <div class="mb-3">
          <label class="form-label fw-500" style="color: #2c3e50;">Email Address</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-envelope" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="email" 
              type="email" 
              placeholder="Enter your email"
              value="{{form.email}}"
              required 
            />
          </div>
        </div>

        <!-- Phone -->
        <div class="mb-3">
          <label class="form-label fw-500" style="color: #2c3e50;">Phone Number</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-telephone" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="phone" 
              type="tel" 
              placeholder="Enter your phone"
              value="{{form.phone}}"
              required 
            />
          </div>
        </div>

        <!-- Password -->
        <div class="mb-3">
          <label class="form-label fw-500" style="color: #2c3e50;">Password</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-lock-fill" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="password" 
              type="password" 
              placeholder="At least 6 characters"
              required 
            />
          </div>
          <small class="text-muted d-block mt-1">
            <i class="bi bi-info-circle me-1"></i>
            Password must be at least 6 characters long
          </small>
        </div>

        <!-- Confirm Password -->
        <div class="mb-4">
          <label class="form-label fw-500" style="color: #2c3e50;">Confirm Password</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-0">
              <i class="bi bi-lock-check" style="color: #2c3e50;"></i>
            </span>
            <input 
              class="form-control border-0 bg-light" 
              name="confirmPassword" 
              type="password" 
              placeholder="Confirm your password"
              required 
            />
          </div>
        </div>

        <!-- Sign Up Button -->
        <button class="btn btn-success w-100 fw-600 py-2" style="background: linear-gradient(90deg, #27ae60 0%, #229954 100%); border: none; border-radius: 8px;">
          <i class="bi bi-person-plus me-2"></i>Create Account
        </button>
      </form>

      <!-- Divider -->
      <div class="d-flex align-items-center my-4">
        <div style="flex: 1; border-bottom: 1px solid #ddd;"></div>
        <span class="px-3 text-muted small">or</span>
        <div style="flex: 1; border-bottom: 1px solid #ddd;"></div>
      </div>

      <!-- Login Link -->
      <div class="text-center mb-4">
        <p class="text-muted mb-0">Already have an account?</p>
        <a href="/ui/login" class="btn w-100 fw-600 py-2" style="background: #3498db; color: white; border: none; border-radius: 8px; margin-top: 0.5rem;">
          <i class="bi bi-box-arrow-in-left me-2"></i>Sign In
        </a>
      </div>

      <!-- Footer -->
      <div class="text-center mt-4">
        <p class="small text-muted">© 2026 AutoRent Pro. All rights reserved.</p>
      </div>
    </div>
  </div>
</div>

<style>
  body {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  }
  .input-group-text {
    border-radius: 8px 0 0 8px !important;
  }
  .form-control {
    border-radius: 0 8px 8px 0 !important;
  }
  .form-control:focus {
    border-color: #27ae60 !important;
    box-shadow: 0 0 0 0.2rem rgba(39, 174, 96, 0.25) !important;
  }
</style>
