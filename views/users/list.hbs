<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
  <div>
    <h1 class="h2 fw-bold mb-1" style="color: #2c3e50;">
      <i class="bi bi-people-fill me-2" style="color: #f39c12;"></i>User Management
    </h1>
    <p class="text-muted small mb-0">Manage all system users</p>
  </div>
  <a class="btn fw-600" href="/ui/users/new" style="background: #f39c12; color: white; border: none; border-radius: 8px; padding: 0.6rem 1.5rem;">
    <i class="bi bi-plus-circle me-2"></i>Add User
  </a>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead style="background: linear-gradient(90deg, #f8f9fa 0%, #f0f2f5 100%); border-bottom: 2px solid #dee2e6;">
        <tr>
          <th class="fw-600" style="color: #2c3e50;">Full Name</th>
          <th class="fw-600" style="color: #2c3e50;">Email</th>
          <th class="fw-600" style="color: #2c3e50;">Phone</th>
          <th class="fw-600" style="color: #2c3e50;">Role</th>
          <th class="fw-600" style="color: #2c3e50; width: 120px;">Actions</th>
        </tr>
      </thead>

      <tbody>
        {{#if users.length}}
          {{#each users}}
            <tr>
              <td>
                <div class="d-flex align-items-center">
                  <div class="avatar" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; margin-right: 0.75rem;">
                    {{this.fullName.[0]}}
                  </div>
                  <span class="fw-500" style="color: #2c3e50;">{{fullName}}</span>
                </div>
              </td>
              <td>
                <small style="color: #7f8c8d;">{{email}}</small>
              </td>
              <td>{{phone}}</td>
              <td>
                {{#ifEquals role "ADMIN"}}
                  <span class="badge" style="background: #fadbd8; color: #c0392b; padding: 0.5rem 0.75rem; border-radius: 6px;">👑 Admin</span>
                {{else ifEquals role "OWNER"}}
                  <span class="badge" style="background: #fdeaa8; color: #d68910; padding: 0.5rem 0.75rem; border-radius: 6px;">🏢 Owner</span>
                {{else}}
                  <span class="badge" style="background: #d5ecf7; color: #2874a6; padding: 0.5rem 0.75rem; border-radius: 6px;">👤 Customer</span>
                {{/ifEquals}}
              </td>
              <td>
                <a href="/ui/users/{{_id}}/edit" class="btn btn-sm btn-outline-primary" style="border-radius: 6px;">
                  <i class="bi bi-pencil"></i>
                </a>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="5" class="text-center py-5">
              <div style="color: #95a5a6;">
                <i class="bi bi-inbox" style="font-size: 2rem; display: block; margin-bottom: 0.5rem;"></i>
                <p class="mb-0">No users found. <a href="/ui/users/new">Add your first user</a></p>
              </div>
            </td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</div>
