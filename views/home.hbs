<!-- Header -->
<div class="mb-4 pb-4 border-bottom">
  <h1 class="h2 fw-bold" style="color: #2c3e50;">
    <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
  </h1>
  <p class="text-muted mt-2 mb-0">Welcome back! Manage your car rental system from here.</p>
</div>

<!-- Dashboard Cards -->
<div class="row g-4">
  <!-- Cars Management -->
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; transition: all 0.3s ease;" 
         onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.1)'"
         onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
      <div class="card-body text-center py-4">
        <div style="font-size: 2.5rem; color: #3498db; margin-bottom: 1rem;">
          <i class="bi bi-car-front-fill"></i>
        </div>
        <h5 class="card-title fw-bold" style="color: #2c3e50;">Car Management</h5>
        <p class="card-text text-muted small mb-3">
          Manage all vehicles in your fleet
        </p>
        <a href="/ui/cars" class="btn btn-primary w-100 fw-600" style="background: #3498db; border: none; border-radius: 8px;">
          <i class="bi bi-arrow-right me-2"></i>View Cars
        </a>
      </div>
    </div>
  </div>

  <!-- Bookings Management -->
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; transition: all 0.3s ease;"
         onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.1)'"
         onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
      <div class="card-body text-center py-4">
        <div style="font-size: 2.5rem; color: #27ae60; margin-bottom: 1rem;">
          <i class="bi bi-calendar-check-fill"></i>
        </div>
        <h5 class="card-title fw-bold" style="color: #2c3e50;">Booking Management</h5>
        <p class="card-text text-muted small mb-3">
          Monitor and manage bookings
        </p>
        <a href="/ui/bookings" class="btn w-100 fw-600" style="background: #27ae60; color: white; border: none; border-radius: 8px;">
          <i class="bi bi-arrow-right me-2"></i>View Bookings
        </a>
      </div>
    </div>
  </div>

  <!-- Users Management -->
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; transition: all 0.3s ease;"
         onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 8px 16px rgba(0,0,0,0.1)'"
         onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
      <div class="card-body text-center py-4">
        <div style="font-size: 2.5rem; color: #f39c12; margin-bottom: 1rem;">
          <i class="bi bi-people-fill"></i>
        </div>
        <h5 class="card-title fw-bold" style="color: #2c3e50;">User Management</h5>
        <p class="card-text text-muted small mb-3">
          Manage system users and permissions
        </p>
        <a href="/ui/users" class="btn w-100 fw-600" style="background: #f39c12; color: white; border: none; border-radius: 8px;">
          <i class="bi bi-arrow-right me-2"></i>View Users
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    transition: all 0.3s ease;
  }
</style>
